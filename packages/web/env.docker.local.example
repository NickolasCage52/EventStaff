# Скопируйте этот файл как .env.local в ЭТОЙ же папке (packages/web):
#   copy env.docker.local.example .env.local
#
# JWT_SECRET — тот же, что в корневом `.env` / на API (Next middleware проверяет access_token).
# NEXT_PUBLIC_WS_URL — origin Socket.io (порт API), если отличается от вычисленного из NEXT_PUBLIC_API_URL.

JWT_SECRET=local-docker-change-me-to-random-string
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
